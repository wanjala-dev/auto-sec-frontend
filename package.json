{
  "name": "auto-sec-frontend",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@dnd-kit/core": "^6.1.0",
    "@dnd-kit/sortable": "^8.0.0",
    "@headlessui/react": "^1.5.0",
    "@heroicons/react": "^2.1.5",
    "@material-ui/core": "^4.12.4",
    "@react-oauth/google": "^0.12.1",
    "@stripe/react-stripe-js": "^1.10.0",
    "@stripe/stripe-js": "^1.35.0",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/postcss7-compat": "npm:@tailwindcss/postcss7-compat",
    "@testing-library/jest-dom": "^5.16.2",
    "@testing-library/react": "^12.1.4",
    "@testing-library/user-event": "^13.5.0",
    "autoprefixer": "^10.4.4",
    "axios": "^0.26.1",
    "chart.js": "^4.4.4",
    "craco": "^0.0.3",
    "d3": "^7.4.4",
    "date-fns": "^2.29.3",
    "dayjs": "^1.11.13",
    "framer-motion": "^6.3.16",
    "lint-staged": "^12.3.6",
    "mapbox-gl": "^2.12.1",
    "postcss": "^8.4.12",
    "qrcode.react": "^4.2.0",
    "quill": "^1.3.7",
    "quill-image-uploader": "^1.2.4",
    "randomcolor": "^0.6.2",
    "react": "18",
    "react-big-calendar": "^1.19.4",
    "react-chartjs-2": "^5.2.0",
    "react-countup": "6.5.3",
    "react-datepicker": "^4.10.0",
    "react-dom": "18",
    "react-icons": "^4.3.1",
    "react-infinite-scroll-component": "^6.1.0",
    "react-loading-skeleton": "^3.5.0",
    "react-lottie": "^1.2.3",
    "react-pdf": "^7.7.2",
    "react-plaid-link": "^4.1.1",
    "react-quill": "^2.0.0",
    "react-router-dom": "^6.2.2",
    "react-scripts": "5.0.0",
    "react-simple-maps": "^2.3.0",
    "react-simple-star-rating": "^4.0.5",
    "react-slick": "^0.30.2",
    "react-spring": "^9.4.5",
    "react-toastify": "^10.0.5",
    "react-tooltip": "^4.2.21",
    "react-use-measure": "^2.1.1",
    "slick-carousel": "^1.8.1",
    "styled-components": "^5.3.5",
    "swiper": "^8.0.7",
    "tailwindcss": "^3.4.19",
    "web-vitals": "^2.1.4"
  },
  "scripts": {
    "start": "craco start",
    "build": "BROWSERSLIST_IGNORE_OLD_DATA=true CI=false craco build",
    "test": "craco test",
    "eject": "craco eject",
    "lint": "eslint --fix --no-error-on-unmatched-pattern \"src/**/*.{js,jsx,ts,tsx}\"",
    "pretty": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "typecheck:workflow": "tsc --noEmit -p tsconfig.workflow.json"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ],
    "rules": {
      "no-restricted-syntax": [
        "error",
        {
          "selector": "Literal[value=/#(42b98f|f5ab5b|f78407)/i]",
          "message": "Brand hex is tokenized — use bg-primary / bg-secondary / bg-tertiary (or var(--primary|--secondary|--tertiary)), never the raw brand hex. This keeps per-workspace theming working. See docs/plans/WORKSPACE_THEMING_DESIGN_2026-07-09.md"
        }
      ]
    },
    "overrides": [
      {
        "files": [
          "src/theme/**"
        ],
        "rules": {
          "no-restricted-syntax": "off"
        }
      },
      {
        "files": [
          "**/*.stories.*"
        ],
        "rules": {
          "import/no-anonymous-default-export": "off"
        }
      },
      {
        "files": [
          "src/context/WorkflowContext.tsx",
          "src/context/workflowServiceAdapters.ts",
          "src/reducer/workflowReducer.ts",
          "src/types/workflow/**/*.ts"
        ],
        "rules": {
          "@typescript-eslint/no-explicit-any": "warn",
          "@typescript-eslint/consistent-type-imports": "warn"
        }
      },
      {
        "files": [
          "public/service-worker.js"
        ],
        "env": {
          "serviceworker": true
        },
        "rules": {
          "no-restricted-globals": "off",
          "strict": "off"
        }
      }
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@types/node": "^20.17.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "@typescript-eslint/parser": "^5.62.0",
    "babel-eslint": "^10.1.0",
    "babel-loader": "8.2.3",
    "eslint": "^8.11.0",
    "eslint-config-react-app": "^7.0.0",
    "eslint-plugin-prettier": "^4.0.0",
    "eslint-plugin-react": "^7.29.4",
    "husky": "^7.0.4",
    "prettier": "^2.6.0",
    "typescript": "^4.9.5",
    "webpack": "5"
  },
  "lint-staged": {
    "**/*.{js,jsx,ts,tsx}": [
      "npm run lint",
      "prettier --write"
    ]
  },
  "overrides": {
    "schema-utils@3": {
      "ajv": "^6.12.6",
      "ajv-keywords": "^3.5.2"
    },
    "schema-utils@4": {
      "ajv": "^8.12.0",
      "ajv-keywords": "^5.1.0"
    }
  }
}
